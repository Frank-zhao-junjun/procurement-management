# Procurement Management System Environment Variables

# Supabase Configuration (必须配置)
COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Fallback (兼容旧配置)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Database (alternative to Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/procurement

# Server Configuration
PORT=5000
NODE_ENV=development

# MCP Server Configuration
MCP_SERVER_PORT=5001
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_ENABLED=true

# MCP Authentication (Optional, recommended for production)
# MCP_API_KEY_SECRET=your-secret-key-for-agent-auth
# MCP_REQUIRE_AUTH=false

# MCP Proxy Configuration (when behind reverse proxy)
# MCP_PROXY_PATH=/mcp
# MCP_PUBLIC_URL=https://purchase.coze.site/mcp

# Feishu Integration (Optional)
# Webhook mode (simple)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# App identity mode (full)
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your-app-secret
FEISHU_BOT_TOKEN=
