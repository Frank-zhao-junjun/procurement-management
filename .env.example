# Procurement Management System Environment Variables

# Supabase Configuration (必须配置)
COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Fallback (兼容旧配置)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 与 Supabase 同一 Postgres 实例的连接串（可选）。
# 配置后服务端多表写入可走事务（transactional-db）；不配置则仅用 Supabase JS 客户端。
DATABASE_URL=postgresql://user:password@localhost:5432/procurement

# Server Configuration
PORT=5000
NODE_ENV=development

# Feishu Integration (Optional)
# Webhook mode (simple)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# App identity mode (full)
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your-app-secret
FEISHU_BOT_TOKEN=
